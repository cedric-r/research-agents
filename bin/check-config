#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../src/bootstrap.php';

use App\Config\Loader;

$projectRoot = dirname(__DIR__);
$agentsDir   = $projectRoot . '/config/agents';
$loader      = new Loader();

$successCount = 0;
$failCount    = 0;

// Validate each agent directory under config/agents/
$agentDirs = glob($agentsDir . '/*', GLOB_ONLYDIR);

if ($agentDirs === false || $agentDirs === []) {
    echo "[INFO] No agent directories found under {$agentsDir}" . PHP_EOL;
}

foreach ($agentDirs as $agentDir) {
    $agentName = basename($agentDir);

    // Validate config.json (required fields: provider, model, api_key)
    $configPath = $agentDir . '/config.json';
    if (file_exists($configPath)) {
        try {
            $loader->load(
                $configPath,
                required: ['provider', 'model', 'api_key'],
                types: ['provider' => 'string', 'model' => 'string', 'api_key' => 'string']
            );
            echo "[OK]   {$agentName}: config.json" . PHP_EOL;
            $successCount++;
        } catch (\Throwable $e) {
            echo "[FAIL] {$agentName}: config.json — " . $e->getMessage() . PHP_EOL;
            $failCount++;
        }
    } else {
        echo "[FAIL] {$agentName}: config.json — File not found" . PHP_EOL;
        $failCount++;
    }

    // Validate preferences.json (must be valid JSON)
    $prefsPath = $agentDir . '/preferences.json';
    if (file_exists($prefsPath)) {
        try {
            $loader->load($prefsPath, required: [], types: []);
            echo "[OK]   {$agentName}: preferences.json" . PHP_EOL;
            $successCount++;
        } catch (\Throwable $e) {
            echo "[FAIL] {$agentName}: preferences.json — " . $e->getMessage() . PHP_EOL;
            $failCount++;
        }
    } else {
        // preferences.json is optional — only warn
        echo "[WARN] {$agentName}: preferences.json — File not found (optional)" . PHP_EOL;
        $successCount++;
    }

    // Validate SOUL.md (must exist and be readable)
    $soulPath = $agentDir . '/SOUL.md';
    if (file_exists($soulPath)) {
        $soulContent = file_get_contents($soulPath);
        if ($soulContent !== false && trim($soulContent) !== '') {
            echo "[OK]   {$agentName}: SOUL.md" . PHP_EOL;
            $successCount++;
        } else {
            echo "[FAIL] {$agentName}: SOUL.md — File is empty or unreadable" . PHP_EOL;
            $failCount++;
        }
    } else {
        echo "[FAIL] {$agentName}: SOUL.md — File not found" . PHP_EOL;
        $failCount++;
    }
}

// Validate arbitrator config if directory exists (Phase 3 placeholder)
$arbitratorPath = $projectRoot . '/config/arbitrator/config.json';
if (file_exists($arbitratorPath)) {
    try {
        $loader->load($arbitratorPath, required: [], types: []);
        echo "[OK]   arbitrator: config.json" . PHP_EOL;
        $successCount++;
    } catch (\Throwable $e) {
        echo "[FAIL] arbitrator: config.json — " . $e->getMessage() . PHP_EOL;
        $failCount++;
    }
}

$total = $successCount + $failCount;
echo PHP_EOL;
echo "Result: {$successCount}/{$total} checks passed" . PHP_EOL;

exit($failCount > 0 ? 1 : 0);
